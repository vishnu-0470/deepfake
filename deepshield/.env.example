# ─────────────────────────────────────────────────────────
#  DeepShield KYC  –  .env.example
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────
SECRET_KEY=your_secret_key_here_change_this_in_production

# ── Server ────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Detection Thresholds ──────────────────────────────────
BLOCK_THRESHOLD=70
REVIEW_THRESHOLD=40

# Layer weights (must sum to 1.0)
WEIGHT_DEEPFAKE_CLASSIFIER=0.30
WEIGHT_RPPG=0.25
WEIGHT_ACOUSTIC=0.20
WEIGHT_ILLUMINATION=0.15
WEIGHT_FACE_MATCH=0.10

# ── Hardware Auth ─────────────────────────────────────────
HW_AUTH_ENABLED=true

# ── CORS ──────────────────────────────────────────────────
# Comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Model ─────────────────────────────────────────────────
CLASSIFIER_MODEL_NAME=efficientnet_b4
CLASSIFIER_CHECKPOINT=deepfake_effnetb4_ff++.pth
CLASSIFIER_FAKE_THRESHOLD=0.55

# ── OCR ───────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract
